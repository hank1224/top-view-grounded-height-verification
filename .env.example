# Copy this file to `.env` and fill in your keys.

OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Model aliases are optional overrides for hosted providers.
# OLLAMA_MODEL is required when running the local Ollama provider for real.
# The hosted-provider runner defaults are:
# - OpenAI: gpt-5.4-2026-03-05
# - Gemini: gemini-3-flash-preview
# - Anthropic: claude-sonnet-4-6
OPENAI_MODEL=gpt-5.4-2026-03-05
GEMINI_MODEL=gemini-3-flash-preview
ANTHROPIC_MODEL=claude-sonnet-4-6
OLLAMA_MODEL=

# Ollama serves its local API here by default. Start it with `ollama serve`
# and pull a vision-capable model before running real Ollama Stage 1 tasks.
OLLAMA_BASE_URL=http://localhost:11434/api

# Per-provider concurrency. Reserved for scripts that support it.
OPENAI_BATCH_SIZE=2
GEMINI_BATCH_SIZE=2
ANTHROPIC_BATCH_SIZE=2
